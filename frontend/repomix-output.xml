        {{ $t('automationRules') || 'قواعد الأتمتة الذكية' }}
      </h1>
      <v-btn
        @click="showRuleModal = true"
        variant="elevated"
        color="primary"
        prepend-icon="mdi-plus"
      >
        {{ $t('newRule') || 'قاعدة جديدة' }}
      </v-btn>
    </div>

    <!-- Rules List -->
    <v-row>
