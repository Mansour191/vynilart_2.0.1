    <!-- Error State -->
    <v-alert
      v-else-if="error"
      type="error"
      variant="tonal"
      class="mb-6"
      closable
      @click:close="error = null"
    >
      <v-alert-title class="d-flex align-center ga-2">
        <v-icon>mdi-alert-circle</v-icon>
