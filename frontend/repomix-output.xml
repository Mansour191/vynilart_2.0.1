                <v-icon color="primary" size="20">mdi-chart-line</v-icon>
                {{ $t('customerBehavior') || 'سلوك العملاء' }}
              </h3>
              <div class="behavior-container" style="height: 400px;">
                <canvas ref="behaviorChart"></canvas>
