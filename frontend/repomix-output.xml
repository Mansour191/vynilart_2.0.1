/* Responsive Design */
@media (max-width: 960px) {
  .page-header {
    flex-direction: column;
    text-align: center;
    gap: 1rem;
  }
}

@media (max-width: 600px) {
  .page-header h1 {
    font-size: 1.5rem;
  }
  
  .rule-details {
    flex-direction: column;
    gap: 0.5rem;
  }
}

/* Vuetify Overrides */
:deep(.v-card) {
