              class="mb-4"
            />

            <div class="d-flex ga-3 justify-end">
              <v-btn
                @click="closeModal"
                variant="tonal"
                color="default"
              >
                {{ $t('cancel') || 'إلغاء' }}
              </v-btn>
              <v-btn
                type="submit"
                variant="elevated"
                color="primary"
              >
                {{ $t('save') || 'حفظ' }}
              </v-btn>
