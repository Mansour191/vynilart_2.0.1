  },
  skeletonColor: {
    type: String,
    default: 'surface-variant'
  },
  elevation: {
    type: [String, Number],
    default: 0
  },
  rounded: {
    type: [String, Boolean],
    default: 'lg'
  },
  // Group props
  showGroup: {
    type: Boolean,
    default: false
  },
  groupType: {
    type: String,
    default: 'card', // card, list, table
    validator: (value) => ['card', 'list', 'table'].includes(value)
  },
  listItems: {
    type: Number,
