          fr: '[Traduit par IA] ',
          ch: '[AI翻译] ' // ✅ إضافة اللغة الصينية
        };
        resolve(`${prefixes[targetLang] || ''}${text}`);
      }, 500);
    });
  }
}

export default new AIService();
