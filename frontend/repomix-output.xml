                <div class="d-flex align-center ga-4">
                  <span class="d-flex align-center ga-1">
                    <v-icon size="12">mdi-clock</v-icon>
                    {{ formatTime(notification.time) }}
                  </span>
                  <v-chip
                    :color="getNotificationColor(notification.type)"
                    size="x-small"
