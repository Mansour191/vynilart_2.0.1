.gallery-card:hover .gallery-image {
  transform: scale(1.05);
}

.lightbox-image {
  border-radius: 8px;
}

/* Responsive */
@media (max-width: 600px) {
  .gallery-card {
    margin-bottom: 16px;
  }
}
