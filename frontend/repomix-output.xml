    <!-- Sync History -->
    <v-card variant="elevated" class="mb-6">
      <v-card-title class="pa-4">
        <h3 class="text-h6 font-weight-medium d-flex align-center ga-2">
          <v-icon color="primary">mdi-history</v-icon>
