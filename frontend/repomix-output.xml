                    :class="{
                      active: n <= passwordStrength.score,
                      [passwordStrength.color]: true
                    }"
                  ></div>
                </div>
              </div>

              <v-checkbox
                v-model="form.agreeTerms"
                label="أوافق على الشروط والأحكام"
                color="primary"
