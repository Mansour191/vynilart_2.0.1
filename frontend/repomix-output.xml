:root {
    /* Dark Luxury Color System - متوافق مع Vuetify و Tailwind */
    --color-primary: #D4AF37;      /* Royal Gold */
    --color-secondary: #B8860B;    /* Dark Gold */
    --color-accent: #F5F5F5;       /* Off-White */
    --color-background: #0A0A0A;   /* Charcoal */
    --color-surface: #1A1A1A;      /* Dark Charcoal */
    
    /* الألوان الأساسية - Dark Mode فاخر */
  --bg-deep: #03050a;
  --bg-primary: #0A0A0A;
  --bg-secondary: #1A1A1A;
  --bg-card: #1a1f2e;
  --bg-card-hover: #222837;
  --bg-sidebar: #080b12;
  --bg-header: rgba(10, 10, 10, 0.95);
  
  /* الألوان الذهبية المتطورة */
  --gold-1: #D4AF37;
  --gold-2: #f5d742;
  --gold-3: #ffd966;
  --gold-4: #c9a52c;
  --gold-gradient: linear-gradient(135deg, #d4af37 0%, #f5d742 35%, #ffd966 70%, #d4af37 100%);
  --gold-gradient-soft: linear-gradient(145deg, rgba(212, 175, 55, 0.2) 0%, rgba(245, 215, 66, 0.1) 100%);
  --gold-glow: 0 0 20px rgba(212, 175, 55, 0.3);
  --gold-glow-strong: 0 0 30px rgba(212, 175, 55, 0.6);
  
  /* الخطوط - نظام خطوط متكامل */
  --font-primary: 'Cairo', 'Tajawal', 'Almarai', sans-serif;
  --font-heading: 'Cairo', 'Rubik', sans-serif;
  --font-arabic: 'Cairo', 'Tajawal', 'Almarai', sans-serif;
  --font-numbers: 'Rubik', 'Cairo', monospace;
  
  /* أحجام الخطوط */
  --text-xs: 0.75rem;    /* 12px */
  --text-sm: 0.875rem;   /* 14px */
  --text-base: 1rem;     /* 16px */
  --text-lg: 1.125rem;   /* 18px */
  --text-xl: 1.25rem;    /* 20px */
  --text-2xl: 1.5rem;    /* 24px */
  --text-3xl: 1.875rem;  /* 30px */
  --text-4xl: 2.25rem;   /* 36px */
  --text-5xl: 3rem;      /* 48px */
  
  /* أوزان الخطوط */
  --font-thin: 300;
  --font-normal: 400;
  --font-medium: 500;
  --font-semibold: 600;
  --font-bold: 700;
  --font-extrabold: 800;
  --font-black: 900;
  
  /* تباعد الأسطر */
  --leading-tight: 1.2;
  --leading-normal: 1.5;
