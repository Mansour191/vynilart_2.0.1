                  {{ $t('view') || 'عرض' }}
                </v-btn>
                <v-btn
                  @click="editReview(item)"
                  variant="tonal"
                  color="warning"
                  size="small"
                  prepend-icon="mdi-pencil"
                >
                  {{ $t('edit') || 'تعديل' }}
                </v-btn>
                <v-btn
                  @click="deleteReview(item)"
                  variant="tonal"
                  color="error"
                  size="small"
                  prepend-icon="mdi-delete"
