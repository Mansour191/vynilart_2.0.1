              <div class="d-flex align-center">
                <v-icon class="me-2" color="#d4af37">mdi-table-chart</v-icon>
                {{ $t('pricing.analytics.detailed', 'تحليلات مفصلة') }}
              </div>
              <v-select
                v-model="selectedPeriod"
                :items="periodOptions"
                :label="$t('pricing.analytics.period', 'الفترة الزمنية')"
                variant="outlined"
