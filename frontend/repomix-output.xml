  color: rgb(var(--v-theme-primary));
}

.breadcrumb-current {
  color: rgb(var(--v-theme-on-surface));
  font-weight: 500;
  opacity: 0.7;
}

@media (max-width: 600px) {
  .breadcrumbs-nav {
    padding: 12px 0;
    margin-bottom: 16px;
  }
}
