  };
  return statusMap[status] || status;
};

const getStatusSeverity = (status) => {
  const severityMap = {
    active: 'success',
    inactive: 'warning',
    out_of_stock: 'danger'
  };
  return severityMap[status] || 'info';
};

const getStockStatus = (stock) => {
  if (stock === 0) return 'bg-red-500';
  if (stock < 10) return 'bg-yellow-500';
