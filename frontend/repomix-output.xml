  border: 1px solid rgba(212, 175, 55, 0.2);
}

/* Main Content */
.royal-main {
  position: relative;
  z-index: 1;
  background: linear-gradient(135deg, 
    var(--marble-light) 0%, 
    var(--marble-dark) 25%, 
    #f4f4f5 50%, 
    var(--marble-dark) 75%, 
    var(--marble-light) 100%);
  background-size: 400% 400%;
  animation: marbleShift 15s ease infinite;
  min-height: 100vh;
}

@keyframes marbleShift {
