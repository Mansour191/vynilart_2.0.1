  async getInvestorMetrics(period, dateFrom, dateTo) {
    const INVESTOR_METRICS = gql`
      query InvestorMetrics($period: String, $dateFrom: Date, $dateTo: Date) {
        investorMetrics(period: $period, dateFrom: $dateFrom, dateTo: $dateTo) {
