    <!-- Learning Analytics -->
    <v-card variant="elevated" class="mb-6">
      <v-card-text class="pa-6">
        <h3 class="text-h5 font-weight-bold text-white mb-4 d-flex align-center ga-2">
          <v-icon color="primary" size="24">mdi-chart-bar</v-icon>
