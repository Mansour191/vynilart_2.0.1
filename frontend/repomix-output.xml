   * جلب البلديات بناءً على الولاية
   * @param {string} wilayaCode - رمز الولاية
   * @returns {Promise<Array>} - قائمة البلديات
   */
  async getCommunes(wilayaCode) {
    const cacheKey = `communes_${wilayaCode}`;
    
