        <v-row>
          <v-col cols="12" md="6">
            <v-card variant="outlined" class="analytics-card">
              <v-card-text class="pa-4">
                <h4 class="text-h6 font-weight-medium text-white mb-3">{{ $t('improvementRate') || 'معدل التحسن' }}</h4>
