            role: "system",
            content: `You are a professional translator for an e-commerce platform called "Vinyl Art". 
                      Translate the provided text into ${targetLang}. 
                      Maintain the professional tone and formatting (if any).`
          },
          {
            role: "user",
            content: text
          }
        ],
        temperature: 0.3
      })
    });

