    color: 'grey'
  }
]);

const storageStats = ref({
  used: 10240000000,
  available: 5242880000,
  total: 15462880000
});

const mediaItems = ref([
  {
    id: 1,
    name: 'ملصق حائط زهور',
    type: 'image',
    size: 2457600,
    thumbnail: 'https://picsum.photos/seed/wall1/300/200.jpg',
