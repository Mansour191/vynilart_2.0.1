            </p>
            <v-btn
              :to="'/notifications'"
              variant="outlined"
              color="primary"
              prepend-icon="mdi-view-list"
              @click="isOpen = false"
            >
              {{ $t('viewAll') || 'عرض الكل' }}
            </v-btn>
          </div>
          
          <!-- Notifications List -->
          <v-list v-else density="compact" class="notifications-list" max-height="400">
