[dir="rtl"] {
  font-family: var(--font-arabic);
}

/* تحسين النصوص الصغيرة */
.text-small, .text-muted, .meta-text {
  font-size: var(--text-sm);
  font-weight: var(--font-normal);
  color: var(--text-dim);
}

.text-xs {
  font-size: var(--text-xs);
}

/* تحسين الروابط */
a {
  font-weight: var(--font-medium);
  transition: var(--transition-soft);
}

/* تحسين الأزرار */
button, .btn {
  font-weight: var(--font-semibold);
  letter-spacing: 0.3px;
}

/* تحسين الجداول */
table {
  font-size: var(--text-sm);
}

table th {
  font-weight: var(--font-semibold);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

table td {
  font-weight: var(--font-normal);
}

/* تحسين النماذج */
input, select, textarea {
  font-family: var(--font-primary);
  font-size: var(--text-sm);
}

/* تأثيرات الخط */
.gradient-text {
  background: var(--gold-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: var(--font-bold);
}

/* تحسينات للشاشات الصغيرة */
@media (max-width: 768px) {
  :root {
    --text-4xl: 2rem;
    --text-3xl: 1.75rem;
    --text-2xl: 1.5rem;
    --text-xl: 1.25rem;
  }
}

/* تأكيد أن Font Awesome يعمل بشكل صحيح */
.fa,
.fas,
.far,
.fal,
.fab,
.mdi {
  font-family: inherit;
}

/* أيقونات احتياطية إذا فشل تحميل Font Awesome */
i:not([class*="fa"]):not([class*="mdi"]) {
  font-family: 'Font Awesome 6 Free', 'Font Awesome 6 Brands', 'Material Design Icons', sans-serif;
}

/* إعادة تعيين أيقونات Font Awesome في الظلام */
body:not(.light-mode) .fa,
body:not(.light-mode) .fas,
body:not(.light-mode) .far {
  color: inherit;
}

/* أيقونات محددة للـ Dashboard */
.dashboard-sidebar .nav-icon {
  font-size: 1.2rem;
  width: 1.2rem;
  text-align: center;
  display: inline-block;
}

.header-actions .action-btn i {
  font-size: 1.2rem;
}
