          :text="$t('noSyncHistoryText') || 'لم تتم أي عمليات مزامنة بعد'"
        >
          <v-btn variant="tonal" color="primary" @click="syncAll">
            {{ $t('startFirstSync') || 'بدأ المزامنة الأولى' }}
          </v-btn>
