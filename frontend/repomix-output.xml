    const result = await this.mutate(SET_DEFAULT_ADDRESS, { id });
    return result.data?.setDefaultAddress;
  }

  // Wishlist Queries and Mutations
  async getMyWishlist() {
    const MY_WISHLIST = gql`
      query MyWishlist {
        myWishlist {
