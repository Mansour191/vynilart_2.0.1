            # Check validity
            is_valid, message = coupon.is_valid(user=user, order_value=order_value)
            if not is_valid:
                raise GraphQLError(message)
            
            return coupon
            
        except Coupon.DoesNotExist:
            raise GraphQLError(_('رمز الكوبون غير صحيح'))
        except Exception as e:
