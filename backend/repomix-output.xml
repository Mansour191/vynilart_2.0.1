        """Handle admin notification messages"""
        await self.send(text_data=json.dumps({
            'type': 'admin_notification',
            'notification': event['notification']
        }))
    
    async def system_alert(self, event):
        """Handle system alert messages"""
        await self.send(text_data=json.dumps({
