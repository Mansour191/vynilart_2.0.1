## 🔧 Mutations الشاملة

### 1. إدارة المنتجات (Product Management)

```graphql
# إنشاء منتج جديد
mutation {
  createProduct(input: {
    nameAr: "فينيل فاخر"
    nameEn: "Premium Vinyl"
    slug: "premium-vinyl"
    basePrice: 2500.00
    descriptionAr: "منتج فينيل عالي الجودة"
    descriptionEn: "High quality vinyl product"
    categoryId: 1
    isFeatured: true
    stock: 100
    tags: ["فينيل", "أرضيات", "عالي الجودة"]
  }) {
    success
    message
    product {
      id
      nameAr
      basePrice
    }
  }
}

# تحديث منتج
mutation {
  updateProduct(input: {
    id: "1"
    basePrice: 3000.00
    isFeatured: false
    stock: 150
  }) {
    success
    message
    product {
      id
      basePrice
      isFeatured
      stock
    }
  }
}

# حذف منتج (تعطيل)
mutation {
  deleteProduct(id: "1") {
    success
    message
  }
}

# تحديث مجموعة منتجات
mutation {
  bulkUpdateProducts(
    productIds: ["1", "2", "3"]
    updates: {
      isFeatured: true
      stock: 200
    }
  ) {
    success
    message
    updatedCount
  }
}
```

