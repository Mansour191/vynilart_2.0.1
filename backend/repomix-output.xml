        resolution_note = self.validated_data.get('resolution_note', '')
        notify_user = self.validated_data['notify_user']
        
        try:
            alert = Alert.objects.get(id=alert_id)
            alert.resolve(resolution_note, notify_user)
            return {
                'status': 'success',
