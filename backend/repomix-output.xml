        }
    
    def resolve_top_products(self, info, limit=10):
        if not info.context.user.is_authenticated:
            return []
        
        return models.Product.objects.filter(
            is_active=True
        ).order_by('-base_price')[:limit]
    
    def resolve_customer_stats(self, info):
