    recipient_group = String()
    recipient_segment = String()
    priority = String()
    category = String()
    
    # Metadata and technical fields
    metadata = JSONString()
    action_url = String()
    action_text = String()
    action_button_color = String()
    
    # Status and timing
    expires_at = DateTime()
    
    # Additional data
