            return UpdateOrganization(
                success=False,
                message='المصادقة مطلوبة'
            )
        
        if not info.context.user.is_superuser:
            return UpdateOrganization(
                success=False,
                message='فقط المستخدم المتميز يمكنه تحديث بيانات المؤسسة'
            )
        
        try:
            organization = Organization.objects.get(pk=kwargs.pop('id'))
            
