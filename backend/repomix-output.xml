            ).count(),
            'total_usage': Coupon.objects.aggregate(
                total=models.Sum('used_count')
            )['total'] or 0,
            'most_used': Coupon.objects.order_by('-used_count').first(),
            'recent_usage': CouponUsage.objects.select_related('coupon', 'user').order_by('-used_at')[:10],
        }
        
        return stats


