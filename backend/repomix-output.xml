                )
            
            report = ReviewReport.objects.create(
                review=review,
                user=user,
                reason=input['reason'],
                description=input.get('description')
            )
            
            return ReportReview(
                success=True,
                message="Review reported successfully",
                report=report
            )
            
        except Review.DoesNotExist:
            return ReportReview(
                success=False,
                message="Review not found",
                errors=["Review not found"]
            )
        except Exception as e:
            return ReportReview(
                success=False,
                message=str(e),
                errors=[str(e)]
            )


